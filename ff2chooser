local FadeObjects = {}

local function RegisterFade(obj)
	table.insert(FadeObjects, obj)
end

local function SetFade(value)
	for _, obj in ipairs(FadeObjects) do
		if obj:IsA("Frame") or obj:IsA("TextButton") then
			obj.BackgroundTransparency = value
		elseif obj:IsA("TextLabel") then
			obj.TextTransparency = value
		elseif obj:IsA("UIStroke") then
			obj.Transparency = value
		end
	end
end

local function TweenFade(value, time)
	for _, obj in ipairs(FadeObjects) do
		local props = {}
		if obj:IsA("Frame") or obj:IsA("TextButton") then
			props.BackgroundTransparency = value
		elseif obj:IsA("TextLabel") then
			props.TextTransparency = value
		elseif obj:IsA("UIStroke") then
			props.Transparency = value
		end
		TweenService:Create(
			obj,
			TweenInfo.new(time, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
			props
		):Play()
	end
end

