LP_CUSTOM_LOADER = function(stepOrTime)
	local player = game:GetService("Players").LocalPlayer
	local tweenService = game:GetService("TweenService")

	local function getGui()
		local gui = player.PlayerGui:FindFirstChild("TyrantHubLoader")
		if gui then return gui end

		gui = Instance.new("ScreenGui")
		gui.Name = "TyrantHubLoader"
		gui.ResetOnSpawn = false
		gui.DisplayOrder = 999
		gui.Parent = player.PlayerGui

		local container = Instance.new("Frame")
		container.Name = "Container"
		container.Size = UDim2.new(0, 320, 0, 48)
		container.Position = UDim2.new(0.5, -160, 1, -36)
		container.BackgroundColor3 = Color3.fromRGB(18, 18, 22)
		container.BackgroundTransparency = 0.15
		container.BorderSizePixel = 0
		container.Parent = gui

		local corner = Instance.new("UICorner")
		corner.CornerRadius = UDim.new(0, 8)
		corner.Parent = container

		local stroke = Instance.new("UIStroke")
		stroke.Color = Color3.fromRGB(45, 45, 55)
		stroke.Thickness = 1
		stroke.Transparency = 0.5
		stroke.Parent = container

		local status = Instance.new("TextLabel")
		status.Name = "Status"
		status.Size = UDim2.new(1, -20, 0, 20)
		status.Position = UDim2.new(0, 10, 0, 6)
		status.BackgroundTransparency = 1
		status.Font = Enum.Font.GothamBold
		status.TextSize = 13
		status.TextColor3 = Color3.fromRGB(235, 235, 240)
		status.TextXAlignment = Enum.TextXAlignment.Left
		status.Text = ""
		status.Parent = container

		local sub = Instance.new("TextLabel")
		sub.Name = "Sub"
		sub.Size = UDim2.new(1, -20, 0, 14)
		sub.Position = UDim2.new(0, 10, 0, 26)
		sub.BackgroundTransparency = 1
		sub.Font = Enum.Font.Gotham
		sub.TextSize = 10
		sub.TextColor3 = Color3.fromRGB(120, 120, 135)
		sub.TextXAlignment = Enum.TextXAlignment.Left
		sub.Text = "Tyrant Hub"
		sub.Parent = container

		container.BackgroundTransparency = 1
		status.TextTransparency = 1
		sub.TextTransparency = 1
		stroke.Transparency = 1

		tweenService:Create(container, TweenInfo.new(0.35, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {BackgroundTransparency = 0.15}):Play()
		tweenService:Create(status, TweenInfo.new(0.35, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {TextTransparency = 0}):Play()
		tweenService:Create(sub, TweenInfo.new(0.35, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {TextTransparency = 0}):Play()
		tweenService:Create(stroke, TweenInfo.new(0.35, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {Transparency = 0.5}):Play()

		return gui
	end

	local gui = getGui()
	local container = gui.Container
	local status = container.Status
	local sub = container.Sub

	if stepOrTime == 1 then
		status.Text = "Authenticating.."
		sub.Text = "Tyrant Hub"
	elseif stepOrTime == 2 then
		status.Text = "Connecting to servers.."
		sub.Text = "Tyrant Hub"
	else
		status.Text = "Authenticated in " .. stepOrTime .. "s"
		sub.Text = "Tyrant Hub"

		task.delay(2.5, function()
			if not gui or not gui.Parent then return end
			local fade = TweenInfo.new(0.4, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
			tweenService:Create(container, fade, {BackgroundTransparency = 1}):Play()
			tweenService:Create(status, fade, {TextTransparency = 1}):Play()
			tweenService:Create(sub, fade, {TextTransparency = 1}):Play()
			tweenService:Create(container:FindFirstChildOfClass("UIStroke"), fade, {Transparency = 1}):Play()
			task.delay(0.45, function()
				if gui and gui.Parent then gui:Destroy() end
			end)
		end)
	end
end

